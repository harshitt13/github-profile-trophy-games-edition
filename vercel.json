{
  "public": true,
  "buildCommand": "echo 'Build complete'",
  "functions": {
    "api/**/*.[jt]s": {
      "runtime": "vercel-deno@3.1.1",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/rank-icon-pack-league-of-legends/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
